{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "npm: clean",
      "type": "npm",
      "script": "clean",
      "group": "build"
    },
    {
      "label": "npm: lint",
      "type": "npm",
      "script": "lint",
      "group": "build",
      "problemMatcher": [
        "$eslint-stylish"
      ]
    },
    {
      "label": "npm: build",
      "type": "npm",
      "script": "build",
      "group": "build",
      "problemMatcher": [
        "$tsc"
      ]
    },
    {
      "label": "npm: knip",
      "type": "npm",
      "script": "knip",
      "group": "build"
    },
    {
      "label": "npm: test",
      "type": "npm",
      "script": "test",
      "group": "build",
      "problemMatcher": [
        "$tsc"
      ]
    }
  ]
}
